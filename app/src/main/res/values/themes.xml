<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MiniGroceryDeliveryApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimaryContainer">@color/black</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Surface and Background -->
        <item name="android:windowBackground">@color/surface_gray</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_main</item>
        <item name="colorSurfaceVariant">@color/divider</item>
        <item name="colorOnSurfaceVariant">@color/text_muted</item>

        <item name="colorOutline">@color/divider</item>
        <item name="colorError">@color/error</item>
    </style>

    <style name="Theme.MiniGroceryDeliveryApp" parent="Base.Theme.MiniGroceryDeliveryApp" />

    <!-- Shape Appearance Overlays -->
    <style name="ShapeAppearanceOverlay.Material3.Corner.Medium" parent="">
        <item name="cornerSize">16dp</item>
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="ShapeAppearanceOverlay.Material3.Corner.Large" parent="">
        <item name="cornerSize">28dp</item>
        <item name="cornerFamily">rounded</item>
    </style>
</resources>
